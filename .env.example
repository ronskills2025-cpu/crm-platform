# ═══════════════════════════════════════════════════════════════
# CRM Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and configure your database connection
# Run: npm run start:all
# ═══════════════════════════════════════════════════════════════

# ── Core ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173,http://localhost:5174
LOG_LEVEL=debug

# ── Database (REQUIRED) ────────────────────────────────────────
# Supabase (recommended): Get from Project Settings > Database > Connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Supabase API Keys ──────────────────────────────────────────
# Get these from your Supabase project: Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis (optional) ───────────────────────────────────────────
# Leave empty to use in-memory fallback (works fine for development)
REDIS_URL=

# ── Security ───────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-in-production-32chars!!
JWT_EXPIRES_IN=7d

# ── WhatsApp ───────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_URL=
WHATSAPP_BACKUP_PHONE_NUMBER_ID=
WHATSAPP_BACKUP_ACCESS_TOKEN=
WHATSAPP_RATE_PER_SEC=80
WHATSAPP_CONCURRENCY=25
WHATSAPP_BATCH_SIZE=100

# ── SMS ────────────────────────────────────────────────────────
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
TEXTLOCAL_API_KEY=
TEXTLOCAL_SENDER=
DLT_ENTITY_ID=
SMS_RATE_PER_SEC=50
SMS_CONCURRENCY=50
SMS_BATCH_SIZE=200

# ── Email ──────────────────────────────────────────────────────
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_RATE_PER_SEC=14
EMAIL_CONCURRENCY=30
EMAIL_BATCH_SIZE=100

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_BACKUP_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_RATE_PER_SEC=30
TELEGRAM_CONCURRENCY=20
TELEGRAM_BATCH_SIZE=100

# ── Facebook Messenger ─────────────────────────────────────────
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
FB_PAGE_BACKUP_ACCESS_TOKEN=
FB_PAGE_BACKUP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=
FB_API_VERSION=v21.0
FB_RATE_PER_SEC=200
FB_CONCURRENCY=30
FB_BATCH_SIZE=100

# ── Instagram ──────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BACKUP_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_URL=
INSTAGRAM_RATE_PER_SEC=30
INSTAGRAM_CONCURRENCY=20
INSTAGRAM_BATCH_SIZE=100

# ── Stripe Billing ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise

# ── Shopify ────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=
CART_RECOVERY_DELAY_MS=600000
CART_FOLLOWUP_DELAY_MS=3600000

# ── Rate Limiting & Retries ────────────────────────────────────
MAX_RETRIES=3
PROVIDER_UNHEALTHY_THRESHOLD=50
PROVIDER_UNHEALTHY_COOLDOWN=300
